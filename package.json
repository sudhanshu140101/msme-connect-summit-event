{
  "name": "cimsme-cms",
  "version": "1.0.0",
  "description": "CIMSME Content Management System - Full Stack CMS with Node.js, MySQL, and Admin Panel",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node database/setup.js",
    "reset-db": "node database/setup.js",
    "backup": "node utils/backup.js",
    "seed": "node database/seeders.js",
    "migrate": "node database/migrate.js",
    "test": "echo \"Tests not implemented yet\" && exit 0",
    "lint": "echo \"Linting not configured\" && exit 0",
    "build": "echo \"Build process completed\" && exit 0"
  },
  "keywords": [
    "cms",
    "nodejs",
    "mysql",
    "express",
    "cimsme",
    "content-management",
    "admin-panel",
    "msme",
    "business",
    "chamber"
  ],
  "author": {
    "name": "CIMSME Team",
    "email": "info@cimsme.com",
    "url": "https://cimsme.com"
  },
  "license": "MIT",
  "homepage": "https://cimsme.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/cimsme/cimsme-cms.git"
  },
  "bugs": {
    "url": "https://github.com/cimsme/cimsme-cms/issues"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cashfree-pg": "^5.1.0",
    "cashfree-sdk": "^0.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.2.1",
    "file-type": "^16.5.4",
    "helmet": "^7.2.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.10",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.5",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zeptomail": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "config": {
    "port": 3000,
    "db_name": "cimsme_cms"
  },
  "directories": {
    "doc": "docs",
    "lib": "models",
    "test": "tests"
  },
  "files": [
    "server.js",
    "models/",
    "routes/",
    "controllers/",
    "middleware/",
    "public/",
    "database/",
    "config/",
    "utils/"
  ],
  "nodemonConfig": {
    "watch": [
      "server.js",
      "models/",
      "routes/",
      "controllers/",
      "middleware/",
      "config/"
    ],
    "ext": "js,json,html",
    "ignore": [
      "node_modules/",
      "uploads/",
      "logs/",
      "public/admin/"
    ],
    "delay": 1000
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
