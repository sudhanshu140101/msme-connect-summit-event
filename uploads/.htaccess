# Deny direct browsing; files served only via admin/download.php

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule .* - [F,L]
</IfModule>

# Prevent PHP execution inside uploads
<FilesMatch "\.php$">
  Require all denied
</FilesMatch>

<IfModule mod_php.c>
  php_flag engine off
</IfModule>
