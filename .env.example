# Environment Configuration
# IMPORTANT: Set to 'production' for live deployment, 'development' for local testing
NODE_ENV=production
PORT=3000
BASE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# DATABASE CONFIGURATION
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cimsme_cms
DB_USER=cimsme_admin
DB_PASSWORD=your-secure-database-password-here

# ADMIN CREDENTIALS
ADMIN_EMAIL=admin@cimsme.com
ADMIN_PASSWORD=$2b$10$YourBcryptHashedPasswordHere

# JWT & SECURITY
JWT_SECRET=your-64-character-random-secret-key-generate-using-crypto-module-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CASHFREE PAYMENT GATEWAY
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox
# Change to 'production' when going live

# EMAIL CONFIGURATION (ZeptoMail)
ZEPTO_TOKEN=your_zeptomail_token
ZEPTO_BOUNCE_ADDRESS=bounce@yourdomain.com
ZEPTO_FROM_EMAIL=noreply@yourdomain.com
ZEPTO_FROM_NAME=CIMSME

# CORS CONFIGURATION
CORS_ORIGIN=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# RATE LIMITING
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# FILE UPLOAD
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# REDIS (OPTIONAL - For Session Management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# LOGGING
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# MEMBERSHIP PLANS
MEMBERSHIP_BASIC_FEE=10000
MEMBERSHIP_SILVER_FEE=15000
MEMBERSHIP_GOLD_FEE=25000
MEMBERSHIP_PLATINUM_FEE=50000

# FEATURE FLAGS
ENABLE_PAYMENTS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
MAINTENANCE_MODE=false
